             "dependency with: pip install chromadb-client"
         ) from e
 
+    # NIGHTJAR PATCH (AGPL integration): embedded / local-only ChromaDB.
+    # When CHROMADB_PERSIST_DIR is set, use an on-disk PersistentClient instead
+    # of the client-server HttpClient — no docker service, "runs on any laptop,
+    # nothing extra to install". Upstream HttpClient behavior is unchanged when
+    # the env var is absent.
+    persist_dir = os.getenv("CHROMADB_PERSIST_DIR", "").strip()
+    if persist_dir:
+        os.makedirs(persist_dir, exist_ok=True)
+        client = chromadb.PersistentClient(path=persist_dir)
+        client.heartbeat()
+        _client = client
+        logger.info(f"ChromaDB embedded (PersistentClient): {persist_dir}")
+        return _client
+
