+def _image_api_style(base_url: str) -> str:
+    """Return the image-API dialect for a resolved endpoint base: "openrouter" or "openai".
+
+    OpenRouter's Unified Image API lives at ``<base>/images`` (base already ends in
+    ``/api/v1``), whereas OpenAI-compatible servers expose ``<base>/images/generations``.
+    Both return ``{data: [{b64_json|url}]}``, so only the path (and size flexibility)
+    differ. Auto-detected from the host via Odysseus's provider detection; overridable
+    with ``NIGHTJAR_IMAGE_API_STYLE=openrouter|openai`` (used by the mock e2e test, where
+    the fake server runs on localhost and can't match the real openrouter.ai host).
+    """
+    import os
+
+    style = os.environ.get("NIGHTJAR_IMAGE_API_STYLE", "").strip().lower()
+    if style in ("openrouter", "openai"):
+        return style
+    try:
+        from src.llm_core import _detect_provider
+
+        return "openrouter" if _detect_provider(base_url) == "openrouter" else "openai"
+    except Exception:
+        return "openai"
+
+
