# Nightjar Telegram scheduler — copy to .env and fill in for a real deploy.
# Every value has a safe default; with NONE of these set the server runs in keyless mock mode
# (MockTransport + mock parser) so you can smoke-test the pipeline offline.

# --- Telegram (leave BOT_TOKEN blank to stay in mock mode) ---
# Create a bot with @BotFather, paste the token here.
BOT_TOKEN=

# --- LLM provider (mock | anthropic | openai) ---
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_MODEL=              # blank → provider default (anthropic: claude-opus-4-8)

# --- HTTP API ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# Strongly recommended in production: without it, anyone who can reach the port can inject
# reminders for any Telegram id. Requests must then send: Authorization: Bearer <API_TOKEN>
# API_TOKEN=change-me

# --- Behavior ---
DAILY_CAP=50             # max reminder parses per user per UTC day (guards a shared LLM key)
DEFAULT_TZ=UTC           # timezone for users who haven't run /tz

# --- Storage ---
# Must be a PERSISTENT volume in production so reminders survive a restart.
DATA_DIR=/data
