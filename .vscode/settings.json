{
  // Quiet VS Code source-control decorations ("dots") for repos that aren't
  // Nightjar's own working changes:
  //   - research/* upstream clones (opencode, row-bot, open-webui, orb-ui,
  //     gemma-chat) are git-IGNORED dev references, each with its own .git, so
  //     VS Code auto-detects them as separate repos.
  //   - research/odysseus is a real SUBMODULE whose working tree is INTENTIONALLY
  //     patched (phase2-odysseus/odysseus-patches/), so VS Code perpetually shows
  //     it as "modified". There's nothing to commit there — the patch is by design
  //     — so ignore it in the SCM view too. (The submodule still works normally on
  //     the git CLI; the pinned commit is still tracked.)
  "git.ignoredRepositories": [
    "research/gemma-chat",
    "research/opencode",
    "research/open-webui",
    "research/orb-ui",
    "research/row-bot",
    "research/odysseus"
  ]
}
