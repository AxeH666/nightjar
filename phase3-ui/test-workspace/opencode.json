{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": { "npm": "@ai-sdk/openai-compatible", "name": "llama.cpp",
      "options": { "baseURL": "http://127.0.0.1:8086/v1" },
      "models": { "qwen3-4b-instruct-2507": { "name": "Qwen3-4B" } } }
  },
  "agent": {
    "coding": { "mode": "primary", "description": "Local coding agent (scoped + edits gated)",
      "permission": {
        "*": "deny",
        "read": "allow", "list": "allow", "glob": "allow", "grep": "allow",
        "edit": "ask", "write": "ask", "bash": "ask"
      } }
  }
}
