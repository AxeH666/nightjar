{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8086/v1"
      },
      "models": {
        "qwen3-4b-instruct-2507": {
          "name": "Qwen3-4B-Instruct-2507 Q4_K_M (llama.cpp)"
        }
      }
    }
  },
  "mcp": {
    "nightjar": {
      "type": "local",
      "command": [
        "{env:NIGHTJAR_ROOT}/phase2-mcp/venv/bin/python",
        "{env:NIGHTJAR_ROOT}/phase2-mcp/mcp_server.py"
      ],
      "environment": {
        "NIGHTJAR_DATA_DIR": "{env:HOME}/.nightjar",
        "NIGHTJAR_WHISPER_SIZE": "base.en",
        "OLLAMA_HOST": "http://localhost:11434"
      },
      "enabled": true,
      "timeout": 120000
    }
  }
}
